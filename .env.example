# translations-agent — environment variables
#
# Copy this file to `.env` and set exactly one of the API keys below.
# If both keys are set, the CLI will prompt you to choose a provider at startup.

# OpenAI Agents SDK — default model: gpt-4o
# Override with --model <name>
OPENAI_API_KEY=

# Anthropic Claude Agent SDK — default model: claude-opus-4-7
# Override with --model <name>
ANTHROPIC_API_KEY=
